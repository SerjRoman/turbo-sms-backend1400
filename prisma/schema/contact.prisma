model Contact {
  id            Int      @id @default(autoincrement())
  localName     String
  avatar        String
  addedAt       DateTime @default(now())
  contactUser   User     @relation(name: "ContactOf", fields: [contactUserId], references: [id])
  contactUserId Int
  owner         User     @relation(name: "ContactToOwner", fields: [ownerId], references: [id])
  ownerId       Int

  @@unique([contactUserId, ownerId])
}