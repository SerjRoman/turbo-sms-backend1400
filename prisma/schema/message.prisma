model Message {
  id        Int      @id @default(autoincrement())
  type      String
  text      String?
  mediaUrl  String?
  sender User @relation(fields: [senderId], references: [id])
  senderId  Int
  // chatAsLastMessage 
  chat Chat @relation(fields: [chatId], references: [id])
  chatId    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
}
